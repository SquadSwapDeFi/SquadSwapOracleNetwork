# ═══════════════════════════════════════════════
# Squad Oracle Network — Node Configuration
# ═══════════════════════════════════════════════

# Operator wallet private key (auto-generated by setup.sh)
OPERATOR_PRIVATE_KEY=0x...

# Contract addresses (BNB Chain)
ORACLE_ADDRESS=0xF799d1ebc55B6FD1896714b92852a49b87461fB0
REGISTRY_ADDRESS=0xbc2D232c35B876d903FEce4a6a37AB81d088e12F
# BNB Chain mainnet. For testnet, replace with your deployed mock token address.
# Used for both staking (operator deposits SQUAD here) AND as the `baseToken`
# argument when reading the SquadSwap V2 cumulative-price TWAP — without it
# set, the SQUAD/USD feed silently skips every round (no on-chain attempt).
SQUAD_TOKEN_ADDRESS=0x2d2567DeC25c9795117228aDC7FD58116D2E310C

# BNB Chain RPC
RPC_BSC=https://bsc-dataseed.binance.org/

# SquadSwap V2 pool address for the SQUAD/USD DEX TWAP feed. REQUIRED — the
# feed reads price0CumulativeLast / price1CumulativeLast from this pool and
# produces a 30-minute TWAP. First on-chain submission lands ~24 minutes
# after node start (TwapTracker fill-ratio = 0.8 of the 1800s window). If
# unset, the SQUAD/USD round logs "missing provider or pool address" and
# skips, with no on-chain attempt.
SQUAD_POOL_ADDRESS=0x68b30366d35d7b8dd7bb7207bc543b76710226c9

# Node settings (defaults are fine for most operators)
METRICS_PORT=9090
LOG_LEVEL=info

# ── P2P (multi-operator consensus) ──
# Default: ON. Every operator node joins the libp2p gossipsub mesh and
# contributes signatures to the BFT quorum. A solo node (single subscribed
# operator on-chain) still works — the feedLoop takes a fast path when
# feedOpCount <= 1 and submits with only its own signature.
#
# Set P2P_ENABLED=false only for isolated local dev where you want to
# disable all libp2p plumbing.
P2P_ENABLED=true
# TCP port libp2p listens on when P2P_ENABLED=true. The container exposes 9091
# in docker-compose.yml; open it in your host/cloud firewall so peers can dial.
P2P_PORT=9091
# Comma-separated libp2p multiaddrs of other subscribed operators. Format:
#   /ip4/<public-ip>/tcp/<port>/p2p/<peerId>
# At least one working entry is required; libp2p will learn the rest of the
# mesh via pubsub-peer-discovery + gossipsub peer-exchange after the first
# connection.
P2P_BOOTSTRAP_NODES=/ip4/174.138.7.3/tcp/9091/p2p/12D3KooWSZAMviAqHDDQtPs5ZuLe2sdboSCzTiCX8mFSfp6eqs2a,/ip4/146.190.102.39/tcp/9091/p2p/12D3KooWMLwkTfczZJP7FcSKYAeq9jh15DTE9QwNq3HMfcQ64cnq,/ip4/157.230.129.91/tcp/9091/p2p/12D3KooWPBvg8XNxpAjHZpYY6RvmTsF51U8bXyNXaA4SxrHQGxa1
# This host's externally-routable public IPv4. setup.sh / update.sh detect
# it automatically via api.ipify.org and write it here. REQUIRED for Docker
# deployments — without it libp2p only sees the container's bridge IP
# (172.x.x.x) and broadcasts that to other operators via pubsub-peer-discovery,
# which they cannot dial across the public internet. Override manually if you
# need IPv6, a non-default NIC, or a custom relay address.
P2P_PUBLIC_IP=

# Optional: token to access the /logs endpoint on the node's HTTP server.
# Must be sent via the `Authorization: Bearer <token>` header — query-string
# tokens are NOT accepted (they leak into proxy/access logs).
#   curl -H "Authorization: Bearer $LOGS_TOKEN" http://localhost:9090/logs
# Leave empty to disable the log endpoint entirely (default, safer).
# Generate a random value with: openssl rand -hex 32
# Keep port 9090 firewalled from the public internet even with this set.
LOGS_TOKEN=
